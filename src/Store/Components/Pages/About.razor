@page "/about"
@rendermode InteractiveServer

<PageTitle>About</PageTitle>

<h1>About TinyShop</h1>

@if (hasQueryParams)
{
    <p>Welcome to the About page. Query parameters detected.</p>
}
else
{
    <div class="alert alert-warning" role="alert">
        This page requires query parameters to function properly. Please add some query parameters to the URL (e.g., <code>?param=value</code>).
    </div>
}

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private bool hasQueryParams;

    protected override void OnInitialized()
    {
        var uri = new Uri(NavigationManager.Uri);
        hasQueryParams = !string.IsNullOrEmpty(uri.Query);
    }
}
