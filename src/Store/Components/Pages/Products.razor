@page "/products"
@rendermode InteractiveServer
@using Store.Services
@using DataEntities
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject Store.Services.CartService CartService

<PageTitle>Products - TinyShop</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Our Products</h1>
        <a href="/products/debug" class="btn btn-sm btn-outline-secondary">🔍 Debug View</a>
    </div>

    @* Cart messages removed *@

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading products...</span>
            </div>
            <p class="mt-3 text-muted">Loading products...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Error Loading Products</h4>
            <p>@errorMessage</p>
            <hr>
            <p class="mb-0">
                <strong>Troubleshooting Tips:</strong><br/>
                • Check that the Products API is running<br/>
                • Verify the connection in appsettings.json<br/>
                • Try refreshing the page
            </p>
        </div>
    }
    else if (products.Count == 0)
    {
        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">No Products Available</h4>
            <p>The product catalog is currently empty.</p>
            <hr>
            <p class="mb-0">
                <strong>Using Scenario 2 (Database Images)?</strong><br/>
                Make sure to run the LoadImages.ps1 script to load product images:<br/>
                <code>cd Products\SQL && .\LoadImages.ps1</code>
            </p>
        </div>
    }
    else
    {
        <div class="mb-3 text-muted">
            Showing @products.Count product@(products.Count != 1 ? "s" : "")
        </div>

        <div class="products-grid">
            @foreach (var product in products)
            {
                <div class="product-card">
                    <div class="product-image-container">
                        <img src="@ProductService.GetImageUrl(product)" 
                             alt="@product.Name" 
                             class="product-image"
                             loading="lazy"
                             onerror="this.onerror=null; this.style.border='2px solid red'; this.title='Image failed to load'" />
                    </div>
                    <div class="product-details">
                        <h3 class="product-name">@product.Name</h3>
                        <p class="product-description">@product.Description</p>
                        <div class="product-footer">
                            <span class="product-price">@product.Price.ToString("C")</span>
                            <button class="btn btn-primary btn-sm" @onclick="() => AddToCart(product)">Add to cart</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<Product> products = new();
    private bool isLoading = true;
    private string? errorMessage;
    
    private void AddToCart(Product product)
    {
        CartService.Add(product, 1);
        Console.WriteLine($"Added {product.Name} to cart");
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            products = await ProductService.GetProductsPageAsync(9);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Failed to connect to Products API: {ex.Message}";
            Console.WriteLine($"HTTP Error: {ex.Message}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            Console.WriteLine($"Error loading products: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // Cart functionality removed
}
