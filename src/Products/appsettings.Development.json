      {
        "AgentId": "local-agent-gateway",
        "ApiKey": "dev-change-me",
        "DisplayName": "TinyShop Local Agent Gateway"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
