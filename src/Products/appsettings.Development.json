{
  "EmbeddingService": {
    "Endpoint": "http://localhost:8001/embed"
  },
  "ConnectionStrings": {
    "ProductsDb": "Server=(localdb)\\MSSQLLocalDB;Database=TineShopDB;Integrated Security=true;TrustServerCertificate=True;"
  },
  "AgentAccess": {
    "RequestsPerMinute": 60,
    "Agents": [
      {
        "AgentId": "copilot-shopping-agent",
