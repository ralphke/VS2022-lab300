# TinyShop Environment Configuration Template
# Copy this file to .env or .env.local and customize values for your environment

EMBEDDING_SERVICE_ENDPOINT=http://localhost:8001/embed
PRODUCTS_DB_CONNECTION_STRING=Server=(localdb)\MSSQLLocalDB;Database=TineShopDB;Integrated Security=true;TrustServerCertificate=True;
CACHE_DB_CONNECTION_STRING=Data Source=Database.db
AGENT_REQUESTS_PER_MINUTE=60
AGENT_1_ID=copilot-shopping-agent
AGENT_1_API_KEY=dev-change-me
AGENT_1_DISPLAY_NAME=Copilot Shopping Agent
AGENT_2_ID=local-agent-gateway
AGENT_2_API_KEY=dev-change-me
AGENT_2_DISPLAY_NAME=TinyShop Local Agent Gateway
PRODUCT_ENDPOINT_SERVICE=https+http://products
PRODUCT_BROWSER_ENDPOINT=https://localhost:7130
IMAGE_PREFIX=https://raw.githubusercontent.com/MicrosoftDocs/mslearn-dotnet-cloudnative/main/dotnet-docker/Products/wwwroot/images/
DEFAULT_CULTURE=en-IE
ENABLE_HTTPS_REDIRECTION=true
ALLOWED_HOSTS=*
LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_ASPNETCORE=Warning
LOG_LEVEL_EF_COMMAND=Information
LOG_LEVEL_ASPIRE_DCP=Warning
ASPNETCORE_ENVIRONMENT=Development
